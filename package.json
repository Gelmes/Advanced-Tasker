{
  "name": "advanced-tasker",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@expo/metro-runtime": "~56.0.13",
    "expo": "~56.0.8",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.8"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "export:web": "expo export --platform web",
    "desktop": "npm run export:web && electron electron/main.js",
    "desktop:dist": "npm run export:web && electron-builder --win"
  },
  "build": {
    "appId": "com.advancedtasker.app",
    "productName": "Advanced Tasker",
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "private": true
}
