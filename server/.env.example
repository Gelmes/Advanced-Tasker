# Copy to .env.local for local runs (gitignored). On Railway, set these as service
# variables instead — never commit real secrets.

# Postgres connection. On Railway, reference the DB service so it's injected:
#   DATABASE_URL = ${{ Postgres.DATABASE_URL }}
# Locally, paste a connection string (e.g. Railway's PUBLIC url) here.
DATABASE_URL=postgres://user:password@host:5432/dbname

# Set true ONLY when connecting over a public/SSL endpoint (Railway INTERNAL = false).
DATABASE_SSL=false

# Shared secret the app sends as `Authorization: Bearer <token>`.
# Generate a long random string, e.g.:  openssl rand -hex 32
SYNC_TOKEN=change-me-to-a-long-random-string

# Railway sets PORT automatically; used only for local runs.
PORT=8080
